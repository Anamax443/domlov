# Zkopíruj na `.dev.vars` a vyplň reálnými hodnotami (soubor .dev.vars je v .gitignore).
# Návod na získání klíčů: docs/BUILD.md (Google Programmable Search Engine).
# Bez těchto hodnot appka funguje taky — jen se nepočítá stopa v Googlu.

GOOGLE_API_KEY=zde-tvuj-google-api-klic
GOOGLE_CX=zde-tvuj-search-engine-id
