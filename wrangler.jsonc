{
  // domlov — Cloudflare Worker (statický frontend + API)
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "domlov",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  // Workers AI — generátor názvů (free denní kvóta)
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
  // Secret (NENÍ v repu): BRAVE_API_KEY  (Brave Search — stopa na webu; volitelný)
  //   lokálně:  .dev.vars   (viz .dev.vars.example)
  //   produkce: npx wrangler secret put BRAVE_API_KEY
}
